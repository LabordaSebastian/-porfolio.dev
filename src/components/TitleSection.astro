---
const { className } = Astro.props
---

<div class="mb-8">
  <h2
    class={`flex items-center text-3xl font-bold tracking-tight gap-x-3 text-[#3d0c0c] dark:text-white ${className ?? ""}`}
  >
    <slot />
  </h2>
  <!-- Gradient accent underline -->
  <div
    class="mt-3 h-px w-20 bg-gradient-to-r from-[#8a6d1b]/70 dark:from-[#c9a84c]/70 to-transparent"
    aria-hidden="true"
  >
  </div>
</div>
