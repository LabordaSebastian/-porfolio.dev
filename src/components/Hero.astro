---
const personalImageAlt = "Laborda Sebastian"
import Badge from "@/components/Badge.astro"
import GitHubIcon from "@/components/icons/GitHub.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import MailIcon from "@/components/icons/Mail.astro"
import SparklesIcon from "@/components/icons/Sparkles.astro"
import SocialPill from "@/components/SocialPill.astro"
---

<div class="max-w-xl">
  <div class="anim-fade-in flex gap-4 mb-6 items-center">
    <!-- Avatar with ambient glow -->
    <div class="relative flex-shrink-0">
      <div
        class="absolute inset-0 rounded-full bg-[#8a6d1b]/15 dark:bg-[#c9a84c]/15 blur-xl scale-125"
        aria-hidden="true"
      >
      </div>
      <img
        class="relative rounded-full shadow-2xl size-20 ring-2 ring-[#8a6d1b]/60 dark:ring-[#c9a84c]/60 ring-offset-2 ring-offset-white dark:ring-offset-[#3d0c0c]"
        src="/midudev.webp"
        alt={personalImageAlt}
      />
    </div>
    <a
      href="https://www.linkedin.com/in/sebastian-laborda-ing"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge><SparklesIcon class="size-3" /> Disponible para trabajar</Badge>
    </a>
  </div>

  <h1
    class="anim-fade-in anim-delay-1 text-4xl font-bold tracking-tight text-[#3d0c0c] sm:text-5xl dark:text-white"
  >
    Hey, soy <span class="gradient-name">Laborda Sebastian</span>
  </h1>

  <p
    class="anim-fade-in anim-delay-2 mt-6 text-xl text-gray-600 dark:text-gray-200 [&>strong]:text-[#8a7530] dark:[&>strong]:text-[#dfc074] [&>strong]:font-semibold"
  >
    <strong>Ingeniero en Telecomunicaciones</strong> de Río Cuarto, Córdoba, Argentina 🇦🇷. Especialista en Infraestructura de Redes (FTTH/GPON) con enfoque en DevOps (Docker, K8s, Linux), Python e Inteligencia Artificial.
  </p>

  <nav
    class="anim-fade-in anim-delay-3 flex flex-wrap gap-4 mt-8"
    aria-label="Redes sociales y contacto"
  >
<SocialPill href="#" onclick="event.preventDefault(); navigator.clipboard.writeText('labordasebastian03@gmail.com').then(() => { this.querySelector('span') ? this.querySelector('span').textContent = 'Mail copiado' : this.textContent = 'Mail copiado' }); setTimeout(() => window.location.hash = '', 2000)">
  <MailIcon class="size-4" />
  <span>Contáctame</span>
</SocialPill>
    <SocialPill href="https://www.linkedin.com/in/sebastian-laborda-ing">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
    <SocialPill href="https://github.com/LabordaSebastian">
      <GitHubIcon class="size-4" />
      GitHub
    </SocialPill>
  </nav>
</div>
